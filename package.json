{
  "name": "otc-to-book",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "check:versions": "node scripts/check-exact-versions.mjs",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "test:e2e": "pnpm --filter web test:e2e",
    "verify": "pnpm check:versions && pnpm lint && pnpm typecheck && pnpm test && pnpm test:e2e",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "turbo": "2.9.18"
  }
}
